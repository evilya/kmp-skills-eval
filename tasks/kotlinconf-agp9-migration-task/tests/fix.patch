===================================================================
diff --git a/androidApp/src/androidMain/kotlin/org/jetbrains/kotlinconf/android/KotlinConfApplication.kt b/androidApp/src/androidMain/kotlin/org/jetbrains/kotlinconf/android/KotlinConfApplication.kt
